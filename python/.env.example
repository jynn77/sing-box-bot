# NODE_PORT — 必填，hy2 + reality 共用端口
NODE_PORT=25983

# Telegram（留空则不推送）
BOT_TOKEN=
CHAT_ID=

# UUID（留空则首次自动生成并持久化）
UUID=

# 节点名称标识（可选，默认自动检测 ISP）
NAME=

# komari-agent 监控（默认开启，false 关闭）
KOMARI_ENABLED=true
KOMARI_SERVER=
KOMARI_TOKEN=

# 节点上传地址（可选）
UPLOAD_URL=

# 自动保活（需设置 PROJECT_URL）
AUTO_ACCESS=false
PROJECT_URL=

# 运行目录（默认 .cache）
FILE_PATH=.cache

# HTTP 端口（默认 3000）
PORT=3000

# 每日重启（true 开启）
DAILY_RESTART=false