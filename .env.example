# Bot Token（从 @BotFather 获取）和 Chat ID，两者都填才推送 TG
BOT_TOKEN=
CHAT_ID=

# 节点名称标识（可选，默认自动检测 ISP）
NAME=

# 端口（hy2 + reality 共用），默认 10280
NODE_PORT=10280

# HTTP 订阅端口，默认 3000
PORT=3000

# 订阅路径，默认 sub —— 访问 http://IP:3000/sub
SUB_PATH=sub

# UUID（自动生成，可自定义）
UUID=

# 订阅自动上传地址（可选，Merge-sub 项目首页地址）
UPLOAD_URL=

# 优选域名/IP（默认 saas.sin.fan）
CFIP=saas.sin.fan

# 优选端口（默认 443）
CFPORT=443

# 运行目录（默认 .npm）
FILE_PATH=.npm

# 下载地址前缀（默认自动）
DOWNLOAD_BASE=https://amd64.ssss.nyc.mn